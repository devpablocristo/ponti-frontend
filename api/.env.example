BASE_MANAGER_API=http://localhost:8080/api/v1

X_API_KEY=local-dev-api-key
IDENTITY_PLATFORM_API_KEY=your-identity-platform-web-api-key
IDENTITY_PLATFORM_PROJECT_ID=your-identity-platform-project-id

# Local dev (sin GCP). Si está en 1, el BFF emite tokens fake y no llama a Identity Platform.
LOCAL_DEV_AUTH=1
LOCAL_DEV_USER_ID=1

# ENABLE_MOCKS=1 activa MSW (mocks). Solo usar para testing aislado del BFF sin backend real.
# Por defecto desactivado: las peticiones van al backend real.
# ENABLE_MOCKS=1